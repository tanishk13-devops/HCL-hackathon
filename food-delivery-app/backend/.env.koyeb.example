# Koyeb environment variables example
ASPNETCORE_ENVIRONMENT=Production
EnableSwagger=false

# Supabase PostgreSQL
DATABASE_URL=postgresql://<user>:<password>@<host>:6543/postgres?sslmode=require

# JWT
Jwt__Key=<very-strong-random-secret-32-plus-chars>
Jwt__Issuer=FoodDeliveryAPI
Jwt__Audience=FoodDeliveryAPI.Client

# Allow your Vercel frontend origin(s)
CORS__ALLOWED_ORIGINS=https://<your-app>.vercel.app